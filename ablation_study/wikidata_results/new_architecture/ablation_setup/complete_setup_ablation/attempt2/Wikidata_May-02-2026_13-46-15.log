y\"\n    },\n    {\n      \"subject\": \"MSC Group\",\n      \"predicate\": \"is owned by\",\n      \"object\": \"Diego Aponte\"\n    },\n    {\n      \"subject\": \"MSC Group\",\n      \"predicate\": \"is owned by\",\n      \"object\": \"Alexa Aponte Vago\"\n    },\n    {\n      \"subject\": \"MSC Group\",\n      \"predicate\": \"is owned by\",\n      \"object\": \"Gianluigi Aponte\"\n    },\n    {\n      \"subject\": \"MSC Group\",\n      \"predicate\": \"is in partnership with\",\n      \"object\": \"Boluda Group\"\n    },\n    {\n      \"subject\": \"Terminal Investment Limited (TiL)\",\n      \"predicate\": \"is in partnership with\",\n      \"object\": \"BlackRock\"\n    },\n    {\n      \"subject\": \"MSC Group\",\n      \"predicate\": \"is in partnership with\",\n      \"object\": \"Mercy Ships\"\n    },\n    {\n      \"subject\": \"The MSC Foundation\",\n      \"predicate\": \"is in partnership with\",\n      \"object\": \"University of Miami\"\n    },\n    {\n      \"subject\": \"The MSC Foundation\",\n      \"predicate\": \"is in partnership with\",\n      \"object\": \"Nova Southeastern University\"\n    }\n  ]\n}"
